{
  "name": "smartbundle",
  "private": true,
  "version": "0.14.2",
  "description": "zero-config bundler for npm packages",
  "bin": "./src/run.ts",
  "type": "module",
  "scripts": {
    "build": "bun src/run.ts",
    "test": "vitest src",
    "test:vitest-compat": "node scripts/test-vitest-compat.js",
    "test:update-snapshots": "pnpm test -- -u",
    "test:e2e": "vitest e2e",
    "test:e2e-update-snapshots": "pnpm test:e2e -- -u"
  },
  "keywords": [
    "smartbundle",
    "bundler",
    "npm",
    "package",
    "typescript",
    "esm",
    "cjs"
  ],
  "author": {
    "name": "Andrey Vassilyev",
    "email": "xavescor@xavescor.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xavescor/smartbundle"
  },
  "homepage": "https://github.com/xavescor/smartbundle",
  "bugs": {
    "url": "https://github.com/xavescor/smartbundle/issues"
  },
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.5.2",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/node": "^20.19.43",
    "@types/semver": "^7.7.1",
    "@types/yargs": "17.0.35",
    "@typescript/typescript6": "^6.0.2",
    "prettier": "^3.9.5",
    "typescript": "7.0.2",
    "vitest": "^4.1.10",
    "vitest-directory-snapshot": "^0.6.1",
    "zx": "^8.8.5"
  },
  "dependencies": {
    "semver": "^7.8.5",
    "vite": "^8.1.4",
    "yargs": "^18.0.0",
    "youch": "4.1.1",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "@babel/core": "^7.26.0",
    "@typescript/typescript6": "^6.0.2",
    "typescript": ">=5.0.0 <8.0.0",
    "vitest": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@babel/core": {
      "optional": true
    },
    "@typescript/typescript6": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "exports": "./src/index.ts"
}
